{
  "select": [
    {
      "label": "mongoToSqlite.test.html — buildSelect",
      "table": "t",
      "schemaHint": "",
      "filter": { "x": 1 },
      "projection": {},
      "sort": {},
      "limit": null,
      "skip": null
    },
    {
      "label": "mongoToSqlite.test.html — filterToWhere $gte",
      "table": "users",
      "schemaHint": "",
      "filter": { "age": { "$gte": 18 } },
      "projection": { "name": 1, "email": 1 },
      "sort": { "id": -1 },
      "limit": null,
      "skip": null
    },
    {
      "label": "mongoToSqlite.test.html — $or",
      "table": "t",
      "schemaHint": "",
      "filter": { "$or": [{ "a": 1 }, { "b": 2 }] },
      "projection": {},
      "sort": {},
      "limit": null,
      "skip": null
    },
    {
      "label": "mongoToSqlite.test.html — projection exclusion (parseSchemaHint a,b,c)",
      "table": "t",
      "schemaHint": "a, b, c",
      "filter": {},
      "projection": { "a": 0 },
      "sort": {},
      "limit": null,
      "skip": null
    },
    {
      "label": "mongoToSqlite.test.html — sortToOrderBy DESC / ASC",
      "table": "t",
      "schemaHint": "",
      "filter": {},
      "projection": { "x": 1, "y": 1 },
      "sort": { "x": -1, "y": 1 },
      "limit": null,
      "skip": null
    },
    {
      "label": "index.html default SELECT",
      "table": "users",
      "schemaHint": "",
      "filter": { "status": "active", "age": { "$gte": 18 } },
      "projection": { "name": 1, "email": 1 },
      "sort": { "created_at": -1 },
      "limit": null,
      "skip": null
    }
  ],

  "insert": [
    {
      "label": "mongoToSqlite.test.html — buildInsert",
      "table": "t",
      "inferColumns": true,
      "docs": [{ "a": 1 }]
    },
    {
      "label": "index.html default INSERT",
      "table": "users",
      "inferColumns": true,
      "docs": [
        { "name": "Ada", "score": 10 },
        { "name": "Bob", "score": 7 }
      ]
    },
    {
      "label": "inferColumns false — columns from first document only (buildInsert)",
      "table": "users",
      "inferColumns": false,
      "docs": [
        { "id": 1, "name": "Alice", "role": "admin" },
        { "id": 2, "email": "bob@x.com", "score": 99 }
      ]
    }
  ],

  "update": [
    {
      "label": "index.html default UPDATE",
      "table": "users",
      "filter": { "_id": 1 },
      "update": { "$set": { "status": "archived" }, "$unset": { "temp": "" } },
      "allowEmptyFilter": false
    },
    {
      "label": "$inc / $mul / $min / $max (buildUpdate)",
      "table": "products",
      "filter": { "id": 1 },
      "update": {
        "$inc": { "views": 1 },
        "$mul": { "price": 1.05 },
        "$min": { "floor_price": 5 },
        "$max": { "ceiling_price": 500 }
      },
      "allowEmptyFilter": false
    },
    {
      "label": "$set plus $rename (warns; $rename has no SET clause)",
      "table": "users",
      "filter": { "_id": 1 },
      "update": { "$set": { "name": "Ann" }, "$rename": { "oldCol": "newCol" } },
      "allowEmptyFilter": false
    },
    {
      "label": "Replacement document (no $ keys)",
      "table": "users",
      "filter": { "_id": 1 },
      "update": { "status": "active", "score": 0 },
      "allowEmptyFilter": false
    }
  ],

  "delete": [
    {
      "label": "index.html default DELETE",
      "table": "users",
      "filter": { "status": "deleted" },
      "allowEmptyFilter": false
    },
    {
      "label": "mongoToSqlite.test.html — buildDelete with empty filter + allowEmptyFilter",
      "table": "t",
      "filter": {},
      "allowEmptyFilter": true
    }
  ],

  "aggregate": [
    {
      "label": "mongoToSqlite.test.html — $match, $group, $sort, $limit",
      "table": "users",
      "pipeline": [
        { "$match": { "status": "active" } },
        { "$group": { "_id": "$region", "total": { "$sum": "$amount" }, "n": { "$sum": 1 } } },
        { "$sort": { "total": -1 } },
        { "$limit": 10 }
      ]
    },
    {
      "label": "mongoToSqlite.test.html — $lookup equality join",
      "table": "users",
      "pipeline": [
        { "$match": { "id": 1 } },
        { "$lookup": { "from": "orders", "localField": "id", "foreignField": "user_id" } }
      ]
    }
  ]
}
