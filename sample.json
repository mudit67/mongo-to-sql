{
  "select": [
    {
      "label": "Users by region and status",
      "table": "users",
      "schemaHint": "",
      "filter": { "region": "north", "status": "active" },
      "projection": { "name": 1, "email": 1, "created_at": 1 },
      "sort": { "created_at": -1 },
      "limit": null,
      "skip": null
    },
    {
      "label": "Adult users with projection",
      "table": "users",
      "schemaHint": "",
      "filter": { "age": { "$gte": 18 } },
      "projection": { "name": 1, "email": 1 },
      "sort": { "_id": -1 },
      "limit": null,
      "skip": null
    },
    {
      "label": "Books by genre or low copies",
      "table": "books",
      "schemaHint": "",
      "filter": { "$or": [{ "genre": "science" }, { "available_copies": { "$lte": 2 } }] },
      "projection": { "title": 1, "genre": 1, "available_copies": 1 },
      "sort": { "published_year": -1 },
      "limit": null,
      "skip": null
    },
    {
      "label": "Users projection exclusion via schemaHint",
      "table": "users",
      "schemaHint": "_id, name, email, status, region, age, created_at",
      "filter": {},
      "projection": { "email": 0, "created_at": 0 },
      "sort": {},
      "limit": null,
      "skip": null
    },
    {
      "label": "Borrow records sorted by status and date",
      "table": "borrows",
      "schemaHint": "",
      "filter": {},
      "projection": { "user_id": 1, "book_id": 1, "status": 1, "borrowed_at": 1 },
      "sort": { "status": 1, "borrowed_at": -1 },
      "limit": null,
      "skip": null
    },
    {
      "label": "Default users SELECT",
      "table": "users",
      "schemaHint": "",
      "filter": { "status": "active", "age": { "$gte": 18 } },
      "projection": { "name": 1, "email": 1 },
      "sort": { "created_at": -1 },
      "limit": null,
      "skip": null
    }
  ],

  "insert": [
    {
      "label": "Insert one user",
      "table": "users",
      "inferColumns": true,
      "docs": [
        {
          "_id": "usr_sample_001",
          "name": "Ada Lovelace",
          "email": "ada.lovelace@example.com",
          "status": "active",
          "region": "north",
          "age": 36,
          "created_at": "2026-01-15T10:00:00.000Z"
        }
      ]
    },
    {
      "label": "Insert two books",
      "table": "books",
      "inferColumns": true,
      "docs": [
        {
          "_id": "book_sample_001",
          "title": "Practical SQL Patterns",
