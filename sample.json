          "available_copies": 3,
          "created_at": "2026-02-01T09:45:00.000Z"
        }
      ]
    },
    {
      "label": "Insert borrows with inferColumns=false",
      "table": "borrows",
      "inferColumns": false,
      "docs": [
        {
          "_id": "brw_sample_001",
          "user_id": "usr_sample_001",
          "book_id": "book_sample_001",
