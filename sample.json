  ],

  "update": [
    {
      "label": "Default users UPDATE",
      "table": "users",
      "filter": { "email": "bob.stone@example.com" },
      "update": { "$set": { "status": "blocked" } },
      "allowEmptyFilter": false
    },
    {
      "label": "$inc / $mul / $min / $max on books",
      "table": "books",
      "filter": { "genre": "technology" },
      "update": {
        "$inc": { "available_copies": 1 },
        "$mul": { "published_year": 1 },
        "$min": { "published_year": 2000 },
        "$max": { "available_copies": 10 }
      },
      "allowEmptyFilter": false
    },
    {
      "label": "$set plus $rename warning on users",
      "table": "users",
      "filter": { "region": "north" },
      "update": { "$set": { "status": "active" }, "$rename": { "nickname": "display_name" } },
      "allowEmptyFilter": false
    },
    {
      "label": "Replacement document on borrows",
      "table": "borrows",
      "filter": { "status": "borrowed" },
      "update": {
        "status": "returned",
        "returned_at": "2026-03-15T00:00:00.000Z"
      },
      "allowEmptyFilter": false
    }
  ],

  "delete": [
    {
      "label": "Delete returned borrows",
      "table": "borrows",
      "filter": { "status": "returned" },
      "allowEmptyFilter": false
    },
    {
      "label": "Delete all inactive users (explicit allow)",
      "table": "users",
      "filter": {},
      "allowEmptyFilter": true
    }
  ],

  "aggregate": [
    {
      "label": "Group users by region",
      "table": "users",
      "pipeline": [
        { "$match": { "status": "active" } },
        { "$group": { "_id": "$region", "n": { "$sum": 1 }, "avg_age": { "$avg": "$age" } } },
        { "$sort": { "n": -1 } },
        { "$limit": 10 }
      ]
    },
    {
      "label": "Borrows lookup users by user_id",
      "table": "borrows",
      "pipeline": [
        { "$match": { "status": "borrowed" } },
        { "$lookup": { "from": "users", "localField": "user_id", "foreignField": "_id" } }
      ]
    },
    {
      "label": "Borrows lookup books by book_id",
      "table": "borrows",
      "pipeline": [
        { "$match": { "status": "borrowed" } },
        { "$lookup": { "from": "books", "localField": "book_id", "foreignField": "_id" } }
      ]
    }
  ]
}
