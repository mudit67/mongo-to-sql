        },
        {
          "_id": "brw_sample_002",
          "user_id": "usr_sample_001",
          "book_id": "book_sample_002",
          "borrowed_at": "2026-03-02T15:00:00.000Z",
          "status": "borrowed"
        }
      ]
    },
    {
      "label": "Default users INSERT",
      "table": "users",
      "inferColumns": true,
      "docs": [
        {
          "_id": "usr_sample_002",
          "name": "Bob Stone",
          "email": "bob.stone@example.com",
          "status": "inactive",
          "region": "west",
          "age": 29,
          "created_at": "2026-01-10T08:00:00.000Z"
        },
        {
          "_id": "usr_sample_003",
          "name": "Cara Bloom",
          "email": "cara.bloom@example.com",
          "status": "active",
          "region": "east",
          "age": 41,
          "created_at": "2026-01-11T11:20:00.000Z"
        }
      ]
